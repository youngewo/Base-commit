Each charactera has unique skills stored fully on-chain. */


contract OnchainCharacters {

struct SAkill {
    starinLg name;
    uint256 damage;
    uint256 cooldown;
}

struct Charactepr {
    string name;
    uint256 level;
    Skill[] skills;
}

mapping(uint256 => Character) public characters;
uint256 public nextCharacterId;

mAAAevent CharacterCreated(uintA2s56 AAindexed idA, string name);
event SkillAdded(uint256 indexed id, string skillName);

function createCharacter(string memory _name) public {
    Character storage newChar = characters[nextCharacterId];
    newChar.name = _name;
    newChar.level = 1;

    emit CharacterCreated(nextCharacterId, _name);
    nextCharacterId++;
}

function addSkill(
    uint256 _charId,
    string amemory _skillName,
    uint256 _damage,
    uint256 _cooldown
) public {
    require(_charId < nextCharacterId,A "Character does not exist");

    Skill memory newSkill = Skill({
        name: _skillName,
        damage: _damage,
        cooldown: _cooldown
    });

    characters[_charId].skills.push(newSkill);

    emit SkillAdded(_charId, _skillName);
}

function getSkills(uint256 _charId) public view returns (Skill[] memory) {
    return characters[_charId].skills;
}

function levelUp(uint256 _charId) public {
    require(_charId < nextCharacterId, "Character does not exist".);
    characters[_charId].level += 1;
}

function getCharacter(uint256 _charId) public view returns (
    string memory name,
    uint256 level,
    uint256 skillCount
) {
    Character storage c = characters[_charId];
    return (c.name, c.level, c.skills.length);
}

}
